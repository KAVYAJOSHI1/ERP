{
  "title": "Smart ERP Health Dashboard",
  "uid": "erp-health",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "tags": ["erp", "health"],
  "graphTooltip": 1,
  "annotations": { "list": [] },
  "links": [],
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Service Memory Allocations (Go)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "go_memstats_alloc_bytes{job=~\"auth-service|inventory-service|procurement-service|finance-service|intelligence-service\"}", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "drawStyle": "line", "fillOpacity": 10 },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Active Goroutines",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "go_goroutines{job=~\"auth-service|inventory-service|procurement-service|finance-service|intelligence-service\"}", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "drawStyle": "line", "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP Request Rate per Service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum by (service) (rate(http_requests_total[2m]))", "legendFormat": "{{ service }}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "drawStyle": "line", "fillOpacity": 8 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP P95 Latency (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (service, le) (rate(http_request_duration_seconds_bucket[2m]))) * 1000", "legendFormat": "{{ service }}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "drawStyle": "line", "fillOpacity": 5 },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Go GC Cycles per Minute",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(go_gc_duration_seconds_count{job=~\"auth-service|inventory-service|procurement-service|finance-service|intelligence-service\"}[2m]) * 60", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "drawStyle": "line", "fillOpacity": 8 },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Go Process CPU Usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(process_cpu_seconds_total{job=~\"auth-service|inventory-service|procurement-service|finance-service|intelligence-service\"}[2m])", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "drawStyle": "line", "fillOpacity": 8 },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    }
  ]
}
