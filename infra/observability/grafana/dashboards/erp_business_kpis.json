{
  "title": "ERP Business KPIs",
  "uid": "erp-business-kpis",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "tags": ["erp", "business"],
  "graphTooltip": 1,
  "annotations": { "list": [] },
  "links": [],
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Auth & Identity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Successful Logins (1h)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "increase(erp_auth_logins_total{status=\"success\"}[1h])", "legendFormat": "", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Failed Logins (1h)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "increase(erp_auth_logins_total{status=\"invalid_credentials\"}[1h])", "legendFormat": "", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 } ] },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "New Registrations (1h)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "increase(erp_auth_registrations_total{status=\"success\"}[1h])", "legendFormat": "", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Token Refreshes (1h)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "increase(erp_auth_token_refreshes_total{status=\"success\"}[1h])", "legendFormat": "", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Login Attempts Over Time",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(erp_auth_logins_total{status=\"success\"}[5m])", "legendFormat": "Success", "refId": "A" },
        { "expr": "rate(erp_auth_logins_total{status=\"invalid_credentials\"}[5m])", "legendFormat": "Invalid Credentials", "refId": "B" },
        { "expr": "rate(erp_auth_logins_total{status=\"failure\"}[5m])", "legendFormat": "System Failure", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "drawStyle": "line", "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Success" }, "properties": [ { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "Invalid Credentials" }, "properties": [ { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } } ] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 7,
      "type": "row",
      "title": "Inventory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false
    },
