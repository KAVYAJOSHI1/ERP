      "title": "Stock Adjustments by Type",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(erp_inventory_stock_adjustments_total[5m])", "legendFormat": "{{ type }}", "refId": "A" },
        { "expr": "rate(erp_inventory_reorder_alerts_total[5m])", "legendFormat": "reorder_alert", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "drawStyle": "line", "fillOpacity": 10 },
          "unit": "ops"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "reorder_alert" }, "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 13,
      "type": "row",
